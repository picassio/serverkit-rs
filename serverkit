# Resolve the nginx vhost layout: Debian-style sites-available/sites-enabled
# when present, otherwise the conf.d layout used by the RHEL family. Sets
# SITE_FILE (where the vhost lives) and SITE_LINK (the sites-enabled symlink;
# empty in conf.d layouts, where the vhost file itself is live).
resolve_site_paths() {
    local domain="$1"
    if [ -d "$NGINX_DIR/sites-available" ]; then
        SITE_FILE="$NGINX_DIR/sites-available/${domain}.conf"
        SITE_LINK="$NGINX_DIR/sites-enabled/${domain}.conf"
    else
        SITE_FILE="$NGINX_DIR/conf.d/${domain}.conf"
        SITE_LINK=""
    fi
}

# Reload nginx if we can; on non-systemd or stopped-nginx boxes this is an
# observation, not a fatal error — the config is already on disk either way.
reload_nginx_or_warn() {
    if systemctl reload nginx 2>/dev/null || nginx -s reload 2>/dev/null; then
        return 0
    fi
    print_warning "Could not reload nginx — apply the change manually: systemctl reload nginx (or nginx -s reload)"
}

cmd_add_site() {
    check_root

    DOMAIN="$1"
    PORT="${2:-3000}"

    if [ -z "$DOMAIN" ]; then
        echo "Usage: serverkit add-site <domain> [port]"
        echo ""
        echo "Examples:"
        echo "  serverkit add-site test.builditdesign.com"
        echo "  serverkit add-site myapp.builditdesign.com 3000"
        exit 1
    fi

    resolve_site_paths "$DOMAIN"

    if [ -f "$SITE_FILE" ]; then
        print_warning "Site config already exists: $SITE_FILE"
        read -p "Overwrite? (y/N) " -n 1 -r || true
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 0
        fi
    fi

    print_info "Creating site config for $DOMAIN..."
    mkdir -p "$(dirname "$SITE_FILE")"

    cat > "$SITE_FILE" << EOF
# Site: $DOMAIN
# Created: $(date)

server {
    listen 80;
    server_name $DOMAIN;

    location / {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
EOF

    # Enable the site (Debian layout only — conf.d configs are live as written)
    if [ -n "$SITE_LINK" ]; then
        mkdir -p "$(dirname "$SITE_LINK")"
        ln -sf "$SITE_FILE" "$SITE_LINK"
    fi

    # Test and reload nginx. A stopped nginx (or a non-systemd box) must not
    # raw-abort here — the site file is already written and valid.
    if nginx -t 2>/dev/null; then
        reload_nginx_or_warn
        print_success "Site added: $DOMAIN → localhost:$PORT"
        echo ""
        echo "Next steps:"
        echo "  1. Add DNS record in Cloudflare:"
        echo "     Type: A, Name: ${DOMAIN%%.*}, Content: $(curl -s ifconfig.me)"
        echo "  2. Start your app on port $PORT"
        echo ""
    else
        print_error "Nginx config error. Check: $SITE_FILE"
        if [ -n "$SITE_LINK" ]; then
            rm -f "$SITE_LINK"
        elif mv -f "$SITE_FILE" "${SITE_FILE}.disabled" 2>/dev/null; then
            # conf.d layouts have no enabled/available split — park the broken
            # file so it can't poison an unrelated nginx reload.
            print_info "Broken config parked at: ${SITE_FILE}.disabled"
        else
            print_warning "Remove or fix $SITE_FILE before reloading nginx"
        fi
        exit 1
    fi
}

cmd_list_sites() {
    print_header
    echo ""
    echo "Configured Sites:"
    echo "─────────────────────────────────────────"

    # Debian layout lists sites-enabled; conf.d layouts (RHEL family) list conf.d.
    local sites_dir="$NGINX_DIR/sites-enabled"
    if [ ! -d "$sites_dir" ]; then
        sites_dir="$NGINX_DIR/conf.d"
    fi

    if [ -d "$sites_dir" ]; then
        for site in "$sites_dir"/*.conf; do
            if [ -f "$site" ]; then
                # `|| true`: a vhost without server_name/proxy_pass is data,
                # not an error — never abort the listing under set -e/pipefail.
                DOMAIN=$(grep -m1 "server_name" "$site" | awk '{print $2}' | tr -d ';' || true)
                # Portable port extraction (GNU-only `grep -oP` broke busybox)
                PORT=$(grep -m1 "proxy_pass" "$site" | sed -n 's/.*:\([0-9][0-9]*\).*/\1/p' || true)
                if [ -z "$PORT" ]; then
                    PORT="static"
                fi
                ENABLED="✓"
                printf "  %s %-35s → port %s\n" "$ENABLED" "$DOMAIN" "$PORT"
            fi
        done
    else
        echo "  No sites configured. Run 'serverkit setup-proxy' first."
    fi
    echo ""
}

cmd_doctor() {
    check_installed
    print_header
    echo ""
    print_info "Running diagnostics..."
    echo ""

    ISSUES=0
    FIXED=0
    FIX_MODE="${1:-}"  # --fix to auto-fix

    if [ "$FIX_MODE" = "--fix" ]; then
        check_root
    fi

    doctor_issue() {
        ISSUES=$((ISSUES + 1))
        print_error "$1"
    }

    doctor_ok() {
        print_success "$1"
    }

    doctor_fixed() {
        FIXED=$((FIXED + 1))
        print_success "FIXED: $1"
    }

    doctor_skip() {
        print_warning "SKIP: $1 (run with --fix to auto-fix)"
    }

    # ── 1. Backend service ──────────────────────────────────────
    echo "Backend"
    echo "───────────────────────────────────────"

    if systemctl is-active --quiet $BACKEND_SERVICE 2>/dev/null; then
        doctor_ok "systemd service is running"
    else
        doctor_issue "systemd service is not running"
        if [ "$FIX_MODE" = "--fix" ]; then
            systemctl start $BACKEND_SERVICE 2>/dev/null && doctor_fixed "Started backend service" || print_error "  Could not start service"
        else
            doctor_skip "systemctl start $BACKEND_SERVICE"
        fi
    fi

    if curl -sf http://127.0.0.1:5000/api/v1/system/health > /dev/null 2>&1; then
        doctor_ok "API responding on port 5000"
    else
        if systemctl is-active --quiet $BACKEND_SERVICE 2>/dev/null; then
            doctor_issue "Service running but API not responding on port 5000"
            echo "         Check logs: journalctl -u serverkit -n 30"
        else
            doctor_issue "API not responding (service is down)"
        fi
    fi

    echo ""

    # ── 2. Frontend container ───────────────────────────────────
    FRONTEND_RUNNING=false
    FRONTEND_PORT=""

    if command -v docker >/dev/null 2>&1; then
        echo "Frontend"
        echo "───────────────────────────────────────"

        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "$FRONTEND_CONTAINER"; then
            FRONTEND_RUNNING=true
            # Get the actual host port the container is mapped to
            FRONTEND_PORT=$(docker port "$FRONTEND_CONTAINER" 80 2>/dev/null | head -1 | sed -n 's/.*:\([0-9][0-9]*\).*/\1/p' || true)
            doctor_ok "Container running (port $FRONTEND_PORT)"
        else
            doctor_issue "Container '$FRONTEND_CONTAINER' is not running"
            if [ "$FIX_MODE" = "--fix" ]; then
                cd "$INSTALL_DIR"
                docker compose up -d 2>/dev/null && {
                    sleep 3
                    FRONTEND_PORT=$(docker port "$FRONTEND_CONTAINER" 80 2>/dev/null | head -1 | sed -n 's/.*:\([0-9][0-9]*\).*/\1/p' || true)
                    FRONTEND_RUNNING=true
                    doctor_fixed "Started frontend container (port $FRONTEND_PORT)"
                } || print_error "  Could not start container"
            else
                doctor_skip "docker compose up -d"
            fi
        fi

        if [ "$FRONTEND_RUNNING" = true ] && [ -n "$FRONTEND_PORT" ]; then
            if curl -sf "http://127.0.0.1:$FRONTEND_PORT" > /dev/null 2>&1; then
                doctor_ok "Frontend responding on port $FRONTEND_PORT"
            else
                doctor_issue "Container running but not responding on port $FRONTEND_PORT"
            fi
        fi
    else
        echo "Frontend"
        echo "───────────────────────────────────────"
        doctor_issue "Docker not installed or not in PATH; skipping frontend checks"
    fi

    echo ""

    # ── 3. Nginx ────────────────────────────────────────────────
    echo "Nginx"
    echo "───────────────────────────────────────"

    if systemctl is-active --quiet nginx 2>/dev/null; then
        doctor_ok "nginx is running"
    else
        doctor_issue "nginx is not running"
        if [ "$FIX_MODE" = "--fix" ]; then
            systemctl start nginx 2>/dev/null && doctor_fixed "Started nginx" || print_error "  Could not start nginx"
        else
            doctor_skip "systemctl start nginx"
        fi
    fi

    if nginx -t 2>/dev/null; then
        doctor_ok "nginx config syntax OK"
    else
        doctor_issue "nginx config has errors"
        echo "         Run: nginx -t"
    fi

    # Scan ALL enabled nginx configs for competing server_name _
    # Only serverkit.conf should use server_name _ (the catch-all panel block)
    for SITE_CONF in "$NGINX_DIR/sites-enabled"/*; do
        [ -f "$SITE_CONF" ] || continue
        SITE_NAME=$(basename "$SITE_CONF")
        # Skip all ServerKit-managed configs
        case "$SITE_NAME" in serverkit-*|serverkit.conf) continue ;; esac

        if grep -Eq 'server_name[[:space:]]+_;' "$SITE_CONF" 2>/dev/null; then
            doctor_issue "'$SITE_NAME' uses server_name _ (conflicts with panel, can hijack all traffic)"
            if [ "$FIX_MODE" = "--fix" ]; then
                rm -f "$NGINX_DIR/sites-enabled/$SITE_NAME"
                rm -f "$NGINX_DIR/sites-available/$SITE_NAME"
                doctor_fixed "Removed conflicting '$SITE_NAME'"
            else
                doctor_skip "Remove conflicting '$SITE_NAME' from sites-enabled"
            fi
        fi
    done

    # Ensure serverkit-locations directory exists
    if [ ! -d "$NGINX_DIR/serverkit-locations" ]; then
        print_warning "Missing $NGINX_DIR/serverkit-locations directory"
        if [ "$FIX_MODE" = "--fix" ]; then
            mkdir -p "$NGINX_DIR/serverkit-locations"
            doctor_fixed "Created $NGINX_DIR/serverkit-locations"
        else
            doctor_skip "mkdir -p $NGINX_DIR/serverkit-locations"
        fi
    fi

    # Check for port mismatch between nginx and frontend container
    NGINX_CONF="$NGINX_DIR/sites-available/serverkit.conf"
    if [ -f "$NGINX_CONF" ]; then
        NGINX_FRONTEND_PORT=$(grep -m1 'proxy_pass.*127.0.0.1' "$NGINX_CONF" | head -1 | sed -n 's/.*:\([0-9][0-9]*\).*/\1/p' || true)

        if [ -n "$FRONTEND_PORT" ] && [ -n "$NGINX_FRONTEND_PORT" ]; then
            if [ "$NGINX_FRONTEND_PORT" = "$FRONTEND_PORT" ]; then
                doctor_ok "nginx proxy port ($NGINX_FRONTEND_PORT) matches frontend container ($FRONTEND_PORT)"
            else
                doctor_issue "PORT MISMATCH: nginx proxies to :$NGINX_FRONTEND_PORT but frontend is on :$FRONTEND_PORT"
                if [ "$FIX_MODE" = "--fix" ]; then
                    sed -i "s|proxy_pass http://127.0.0.1:${NGINX_FRONTEND_PORT}|proxy_pass http://127.0.0.1:${FRONTEND_PORT}|" "$NGINX_CONF"
                    if nginx -t 2>/dev/null; then
                        nginx -s reload 2>/dev/null
                        doctor_fixed "Updated nginx to proxy to port $FRONTEND_PORT"
                    else
                        print_error "  nginx config broken after edit — reverting"
                        sed -i "s|proxy_pass http://127.0.0.1:${FRONTEND_PORT}|proxy_pass http://127.0.0.1:${NGINX_FRONTEND_PORT}|" "$NGINX_CONF"
                    fi
                else
                    doctor_skip "Update nginx proxy_pass from :$NGINX_FRONTEND_PORT to :$FRONTEND_PORT"
                fi
            fi
        fi

        # Check API proxy port
        NGINX_API_PORT=$(grep -A1 'location /api' "$NGINX_CONF" | grep proxy_pass | sed -n 's/.*:\([0-9][0-9]*\).*/\1/p' | head -1 || true)
        if [ -n "$NGINX_API_PORT" ]; then
            if ss -tlnp 2>/dev/null | grep -q ":${NGINX_API_PORT}.*gunicorn\|:${NGINX_API_PORT}.*python"; then
                doctor_ok "nginx API proxy port ($NGINX_API_PORT) has backend listening"
            else
                doctor_issue "nginx proxies API to :$NGINX_API_PORT but nothing is listening there"
            fi
        fi
    else
        doctor_issue "nginx config not found: $NGINX_CONF"
    fi

    echo ""

    # ── 4. Docker ───────────────────────────────────────────────
    echo "Docker"
    echo "───────────────────────────────────────"

    if command -v docker &>/dev/null; then
        doctor_ok "Docker installed"
    else
        doctor_issue "Docker not found"
    fi

    if docker info &>/dev/null; then
        doctor_ok "Docker daemon running"
    else
        doctor_issue "Docker daemon not running"
        if [ "$FIX_MODE" = "--fix" ]; then
            systemctl start docker 2>/dev/null && doctor_fixed "Started Docker daemon" || print_error "  Could not start Docker"
        else
            doctor_skip "systemctl start docker"
        fi
    fi

    echo ""

    # ── 5. Disk space ───────────────────────────────────────────
    echo "System"
    echo "───────────────────────────────────────"

    DISK_USAGE=$(df / | awk 'NR==2 {print $5}' | tr -d '%')
    if [ "$DISK_USAGE" -lt 90 ]; then
        doctor_ok "Disk usage: ${DISK_USAGE}%"
    elif [ "$DISK_USAGE" -lt 95 ]; then
        print_warning "Disk usage high: ${DISK_USAGE}%"
    else
        doctor_issue "Disk almost full: ${DISK_USAGE}%"
    fi

    RAM_AVAIL=$(free -m | awk '/Mem:/ {print $7}')
    if [ "$RAM_AVAIL" -gt 100 ]; then
        doctor_ok "Available RAM: ${RAM_AVAIL}MB"
    else
        doctor_issue "Low RAM: ${RAM_AVAIL}MB available"
    fi

    # Check swap
    SWAP_TOTAL=$(free -m | awk '/^Swap:/ {print $2}')
    if [ "$SWAP_TOTAL" -gt 0 ]; then
        doctor_ok "Swap: ${SWAP_TOTAL}MB"
    else
        print_warning "No swap configured (recommended for low-RAM servers)"
    fi

    echo ""

    # ── 6. Database ─────────────────────────────────────────────
    echo "Database"
    echo "───────────────────────────────────────"

    DB_FILE="$INSTALL_DIR/backend/instance/serverkit.db"
    if [ -f "$DB_FILE" ]; then
        DB_SIZE=$(du -h "$DB_FILE" | cut -f1)
        doctor_ok "SQLite database exists ($DB_SIZE)"
    else
        doctor_issue "Database file not found: $DB_FILE"
    fi

    echo ""

    # ── 7. Connectivity ─────────────────────────────────────────
    echo "Connectivity"
    echo "───────────────────────────────────────"

    if curl -sf http://127.0.0.1 > /dev/null 2>&1; then
        doctor_ok "localhost:80 responding"
    else
        doctor_issue "localhost:80 not responding (nginx → frontend broken)"
    fi

    if curl -sf http://127.0.0.1/api/v1/system/health > /dev/null 2>&1; then
        doctor_ok "localhost:80/api proxying to backend"
    else
        doctor_issue "localhost:80/api not reaching backend"
    fi

    echo ""

    # ── Summary ─────────────────────────────────────────────────
    echo "───────────────────────────────────────"
    if [ "$ISSUES" -eq 0 ]; then
        print_success "All checks passed!"
    else
        if [ "$FIX_MODE" = "--fix" ]; then
            echo -e "${YELLOW}Found $ISSUES issue(s), fixed $FIXED${NC}"
            REMAINING=$((ISSUES - FIXED))
            if [ "$REMAINING" -gt 0 ]; then
                echo "$REMAINING issue(s) need manual attention"
            fi
        else
            echo -e "${RED}Found $ISSUES issue(s)${NC}"
            echo "Run 'sudo serverkit doctor --fix' to auto-fix"
        fi
    fi
    echo ""

    # Meaningful exit code so doctor can gate scripts: non-zero while issues
    # remain (with --fix, only the ones that could not be auto-fixed count).
    local remaining="$ISSUES"
    if [ "$FIX_MODE" = "--fix" ]; then
        remaining=$((ISSUES - FIXED))
    fi
    if [ "$remaining" -gt 0 ]; then
        return 1
    fi
    return 0
}

cmd_remove_site() {
    check_root

    DOMAIN="$1"

    if [ -z "$DOMAIN" ]; then
        echo "Usage: serverkit remove-site <domain>"
        cmd_list_sites
        exit 1
    fi

    resolve_site_paths "$DOMAIN"

    if [ ! -f "$SITE_FILE" ]; then
        print_error "Site not found: $DOMAIN"
        exit 1
    fi

    print_warning "This will remove the site config for $DOMAIN"
    read -p "Continue? (y/N) " -n 1 -r || true
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        if [ -n "$SITE_LINK" ]; then
            rm -f "$SITE_LINK"
        fi
        rm -f "$SITE_FILE"
        reload_nginx_or_warn
        print_success "Site removed: $DOMAIN"
    fi
}

