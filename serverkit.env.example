# ServerKit-RS configuration example.
# Copy to /etc/serverkit/serverkit.env (install.sh does this for you) and fill
# in real secrets. NEVER commit a file with real secrets.

# HTTP port the panel listens on.
PORT=5000

# Database — SQLite by default. Path is created on first boot.
DATABASE_URL=sqlite:///var/lib/serverkit/serverkit.db

# Runtime directories.
SK_DATA_DIR=/var/lib/serverkit
SK_FRONTEND_DIST=/opt/serverkit-rs/frontend/dist
SK_TEMPLATES_DIR=/opt/serverkit-rs/templates
SK_SIDECAR_DIR=/opt/serverkit-rs/ai-sidecar
SK_MAGENTO_BACKUP_DIR=/var/lib/serverkit/backups

# Secrets — generate with: openssl rand -hex 32
# SERVERKIT_ENCRYPTION_KEY is a Fernet key:
#   python3 -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
SERVERKIT_ENCRYPTION_KEY=change-me-fernet-key

# --- AI assistant (optional) ------------------------------------------------
# The bundled pi-SDK sidecar auto-starts. Override only if you run it yourself:
# SK_SIDECAR_URL=http://127.0.0.1:5056
# SK_SIDECAR_TOKEN=<shared-secret>
# SK_SIDECAR_AUTOSTART=0        # disable auto-start
# Log in to Claude Pro/Max etc. from Settings → AI Assistant → Provider Login.

# --- Let's Encrypt DNS-01 (optional) ---------------------------------------
# SK_CF_API_TOKEN=<cloudflare-token-with-Zone:DNS:Edit>

# --- Non-interactive admin bootstrap (first boot only) ---------------------
# SK_BOOTSTRAP_ADMIN_EMAIL=you@example.com
# SK_BOOTSTRAP_ADMIN_USERNAME=admin
# SK_BOOTSTRAP_ADMIN_PASSWORD=at-least-8-chars
